{
	"name": "angelic-pastries",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dotenvx": "dotenvx",
		"dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
		"build": "SKIP_YARN_COREPACK_CHECK=0 dotenvx run -f .env.production -- next build --experimental-build-mode compile",
		"start": "next start",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
		"lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
		"stripe:login": "stripe login",
		"stripe:webhooks": "stripe listen --forward-to localhost:3000/api/payments/stripe/webhooks",
		"encrypt-env": "cp .env.production.local .env.production && dotenvx encrypt -f .env.production"
	},
	"dependencies": {
		"@dotenvx/dotenvx": "^1.64.0",
		"@hcaptcha/react-hcaptcha": "^2.0.2",
		"@payloadcms/db-mongodb": "^3.84.1",
		"@payloadcms/email-nodemailer": "^3.84.1",
		"@payloadcms/next": "^3.84.1",
		"@payloadcms/plugin-ecommerce": "^3.84.1",
		"@payloadcms/plugin-stripe": "^3.84.1",
		"@payloadcms/richtext-lexical": "^3.84.1",
		"@payloadcms/ui": "^3.84.1",
		"@radix-ui/react-slot": "^1.2.4",
		"@stripe/react-stripe-js": "^6.3.0",
		"@stripe/stripe-js": "^9.4.0",
		"@swc/core": "^1.15.32",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"dotenv": "^17.4.2",
		"graphql": "^16.13.2",
		"lucide-react": "^1.14.0",
		"next": "16.2.4",
		"payload": "^3.84.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"sharp": "^0.34.5",
		"stripe": "^22.1.0",
		"tailwind-merge": "^3.5.0",
		"turbo": "^2.9.7"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@eslint/migrate-config": "^2.0.6",
		"@hcaptcha/types": "^1.2.0",
		"@next/eslint-plugin-next": "^16.2.4",
		"@payloadcms/eslint-config": "^3.28.0",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/node": "^25",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.2.1",
		"eslint-config-next": "^16.2.4",
		"postcss": "^8",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4.2.4",
		"typescript": "^6"
	},
	"packageManager": "npm@11.13.0"
}
